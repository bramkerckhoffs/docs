{{- $pages := where .Site.RegularPages "Section" "ne" "" -}}
[
{{- range $i, $p := $pages -}}
{{- if $i }},{{ end -}}
{
  "title":   {{ $p.Title | jsonify }},
  "url":     {{ $p.RelPermalink | jsonify }},
  "section": {{ $p.Section | jsonify }},
  "tags":    {{ with $p.Params.tags }}{{ . | jsonify }}{{ else }}[]{{ end }},
  "group":   {{ with $p.Params.group }}{{ . | jsonify }}{{ else }}""{{ end }},
  "summary": {{ with $p.Params.intro }}{{ . | jsonify }}{{ else }}{{ $p.Plain | truncate 140 | jsonify }}{{ end }}
}
{{- end }}
]
